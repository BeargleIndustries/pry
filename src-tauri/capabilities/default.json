{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability grants for the Pry main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:webview:default",
    "core:webview:allow-internal-toggle-devtools",
    "core:window:default",
    "core:path:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "shell:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$LOCALDATA/Pry/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$LOCALDATA/Pry/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    }
  ]
}
